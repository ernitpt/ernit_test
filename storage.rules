rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /hints/{userId}/{allPaths=**} {
      // Allow read/write if the user is authenticated and matches the userId path
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Allow read access to hints for everyone (or restrict to friends if possible, but public read is common for shared content)
    // For now, let's allow authenticated users to read any hint media (since they are shared)
    match /hints/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
