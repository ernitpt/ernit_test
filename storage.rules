rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ========== PROFILE IMAGES ==========
    // Path: profile-images/{userId}/...
    // Anyone can view profiles, only owner can upload
    match /profile-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }
    
    // ========== PERSONALIZED HINTS ==========
    // Path: hints/{userId}/audio/... and hints/{userId}/images/...
    // Uploaded by giver (userId), accessible to giver and goal recipient
    // For simplicity: authenticated users can read (they can only access if they know the URL)
    match /hints/{userId}/{allPaths=**} {
      // Authenticated users can read hints (URLs are only shared with recipient)
      allow read: if request.auth != null;

      // Only the owner (giver) can upload their hints
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/(jpeg|png|gif|webp)')
            || request.resource.contentType.matches('audio/.*'));
    }
    
    // ========== MOTIVATION MEDIA ==========
    // Path: motivations/{userId}/images/... and motivations/{userId}/audio/...
    // Uploaded by giver (userId), accessible to authenticated users
    match /motivations/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/(jpeg|png|gif|webp)')
            || request.resource.contentType.matches('audio/.*'));
    }

    // ========== SESSION MEDIA ==========
    // Path: sessions/{userId}/{goalId}/...
    // Photos/videos captured during goal sessions
    match /sessions/{userId}/{goalId}/{fileName} {
      // SECURITY FIX: Scoped read to the uploading user only (uid segment in path).
      // Previously any authenticated user could read any session media file.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 15 * 1024 * 1024
        && (request.resource.contentType.matches('image/(jpeg|png|gif|webp)')
            || request.resource.contentType.matches('video/.*'));
    }
    
    // ========== EXPERIENCE IMAGES ==========
    // Path: experiences/{userId}/...
    // Public images for the experience shop; write scoped to owning partner UID
    match /experiences/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }

    // ========== PARTNER FILES ==========
    // Path: partners/{userId}/...
    // Write scoped to owning partner UID with content-type restriction
    match /partners/{userId}/{allPaths=**} {
      // SECURITY FIX: Partner files require authentication to read.
      // Previously publicly readable without any auth check.
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }
    
    // ========== USERS FOLDER (legacy/backup) ==========
    match /users/{userId}/{allPaths=**} {
      // SECURITY FIX: Legacy users/ path now requires authentication to read.
      // Previously publicly readable (allow read: if true).
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }
    
    // ========== DEFAULT: Authenticated reads only for any path ==========
    // Prevents breaking existing images stored in unexpected locations
    // SECURITY: Restricted to authenticated users only (was: if true)
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
