rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {


    /** =====================
     * 🔧 HELPERS
     * ===================== **/
    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function partnerUserDoc(uid) {
      return get(/databases/$(database)/documents/partnerUsers/$(uid));
    }

    function isPartner(uid) {
      return partnerUserDoc(uid).exists() &&
             partnerUserDoc(uid).data.userType == 'partner';
    }

    function isAdmin(uid) {
      return partnerUserDoc(uid).exists() &&
             partnerUserDoc(uid).data.isAdmin == true;
    }

    /** =====================
     * 👤 USERS
     * ===================== **/
    match /users/{userId} {
      // User can read any user doc (needed for friend profiles, feed, notifications)
      allow read: if request.auth != null;

      // User can create their own doc
      allow create: if request.auth != null && request.auth.uid == userId;

      // User can update their own doc with field validation
      allow update: if request.auth != null && request.auth.uid == userId
        // Prevent changing immutable fields
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'createdAt'])
        // Validate string lengths if profile fields are being changed
        && (!('displayName' in request.resource.data) || (
            request.resource.data.displayName is string &&
            request.resource.data.displayName.size() <= 100))
        && (!('profile' in request.resource.data) || (
            request.resource.data.profile is map &&
            (!('name' in request.resource.data.profile) || request.resource.data.profile.name.size() <= 100) &&
            (!('description' in request.resource.data.profile) || request.resource.data.profile.description.size() <= 500) &&
            (!('country' in request.resource.data.profile) || request.resource.data.profile.country.size() <= 100)));

      // User can delete their own doc
      allow delete: if request.auth != null && request.auth.uid == userId;

      // User coupons: users/{userId}/coupons/{couponId}
      match /coupons/{couponId} {
        allow create, read, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      // meta subcollection: goalCount, rateLimits — used by GoalService and FriendService
      match /meta/{metaId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    /** =====================
     * 👔 PARTNER USERS
     * ===================== **/
    match /partnerUsers/{partnerId} {
      // Allow rule engine to fetch partnerUser doc when checking admin status.
      // NOTE: Exposes partner PII to all authenticated users. The main app reads
      // partner name/logo for experience display cards, so this broad get is intentional.
      // Consider a Cloud Function proxy for sensitive fields if stricter isolation is needed.
      allow get: if request.auth != null;

      // Partner can read/update their own record
      allow read, update: if request.auth != null && request.auth.uid == partnerId;

      // Admin can list all partners (for admin dashboard)
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true;

      // Create own partner record (from invite)
      allow create: if request.auth != null
        && request.auth.uid == partnerId
        && request.resource.data.userType == 'partner'
        && request.resource.data.createdFromInvite is string;

      // No client deletes
      allow delete: if false;

      /** =======================
       * 🎟 COUPONS SUBCOLLECTION
       * ======================= **/
      match /coupons/{couponId} {
        // ✅ Partner can read and create their own coupons
        // ✅ Admin can read all coupons (for dashboard/analytics)
        allow read: if request.auth != null && request.auth.uid == partnerId;
        allow read, update: if request.auth != null
          && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true;

        // ✅ Partner can update their own coupons
        // SECURITY: Prevent status from going backward (redeemed → active is forbidden)
        allow update: if request.auth != null
          && request.auth.uid == partnerId
          && isPartner(request.auth.uid)
          // Only allow status transitions forward: active → redeemed (not redeemed → active)
          && (!('status' in resource.data) || resource.data.status != 'redeemed' || request.resource.data.status == 'redeemed');

        // ✅ Partner can delete their own coupons (was previously allowed by write)
        allow delete: if request.auth != null && request.auth.uid == partnerId && isPartner(request.auth.uid);

        // ✅ Users can create (generate) coupons for a partner
        // ✅ SECURITY FIX: Corrected validation to use isCompleted field
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid  // coupon belongs to this user
          && request.resource.data.partnerId == partnerId      // coupon linked to this partner
          && request.resource.data.keys().hasAll(['userId', 'partnerId', 'code', 'status', 'createdAt'])
          // ✅ SECURITY: Validate status on creation — must be 'active'
          && request.resource.data.status == 'active'
          // ✅ SECURITY: Verify goal exists and is completed
          && ('goalId' in request.resource.data ? (
            exists(/databases/$(database)/documents/goals/$(request.resource.data.goalId))
            && get(/databases/$(database)/documents/goals/$(request.resource.data.goalId)).data.userId == request.auth.uid
            && get(/databases/$(database)/documents/goals/$(request.resource.data.goalId)).data.isCompleted == true  // ✅ Fixed: use isCompleted instead of status
          ) : true); // Allow creation without goalId for backward compatibility

        // ✅ Users can read their own coupons OR partner can read their coupons
        // SECURITY FIX (HIGH-2): Removed resource == null branch — it enabled existence probing by any authenticated user
        allow get: if request.auth != null && (
          resource.data.userId == request.auth.uid ||
          resource.data.partnerId == request.auth.uid
        );

        // ✅ For collision detection during coupon generation,
        // allow limited queries with specific code filter
        // SECURITY FIX (HIGH-1): Added partner ownership check — previously any authenticated user could enumerate partner coupons
        allow list: if request.auth != null
          && request.auth.uid == partnerId
          && request.query.limit == 1;

      }
    }

    /** =====================
     * 🎯 GOALS
     * ===================== **/
    match /goals/{goalId} {
      // Read: any authenticated user can get a goal by ID.
      // This is required for feed motivation checks, friend profile views,
      // partner progress display, and notification handling.
      // NOTE: list queries still use where('userId', '==', uid) so users can only
      // list their OWN goals. But get-by-ID is open to all authenticated users.
      // Sensitive goal data (session details, hints, media) is in subcollections with tighter rules.
      allow read: if request.auth != null;

      /* ===============================
         RECEIVER PERMISSIONS
         =============================== */

      // Receiver can CREATE their own goal
      // Allow if: user is the goal recipient AND either:
      //   - The experience gift exists (normal flow), OR
      //   - The Valentine challenge exists (Valentine flow)
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && (
          // Normal gift flow: experienceGift must exist
          ('experienceGiftId' in request.resource.data
           && request.resource.data.experienceGiftId != ''
           && exists(/databases/$(database)/documents/experienceGifts/$(request.resource.data.experienceGiftId)))
          ||
          // Valentine flow: valentineChallenge must exist
          ('valentineChallengeId' in request.resource.data
           && exists(/databases/$(database)/documents/valentineChallenges/$(request.resource.data.valentineChallengeId)))
          ||
          // Free Goal flow: must have isFreeGoal flag; pledgedExperience is optional
          ('isFreeGoal' in request.resource.data
           && request.resource.data.isFreeGoal == true
           && (
             // No experience selected: field missing OR null
             !('pledgedExperience' in request.resource.data)
             || request.resource.data.pledgedExperience == null
             ||
             // Experience selected — must be a real experience doc
             (request.resource.data.pledgedExperience.experienceId is string
              && exists(/databases/$(database)/documents/experiences/$(request.resource.data.pledgedExperience.experienceId)))
           ))
        )
        // Value validation on create
        && (!('targetCount' in request.resource.data) ||
            (request.resource.data.targetCount >= 1 && request.resource.data.targetCount <= 5))
        && (!('sessionsPerWeek' in request.resource.data) ||
            (request.resource.data.sessionsPerWeek >= 1 && request.resource.data.sessionsPerWeek <= 7));

        // ===== Allow updates =====
      allow update: if request.auth != null && (

        // (1) Receiver updating their own goal
        // SECURITY: Restrict critical fields when approval is pending or after approval
        (request.auth.uid == resource.data.userId && (
          // Allow all updates if no approval process started OR already approved
          (!('approvalStatus' in resource.data) || resource.data.approvalStatus == 'approved') ||

          // If approval is pending/requested, only allow safe field updates
          (resource.data.approvalStatus in ['pending', 'suggested_change', 'rejected'] &&
           (
             // Allow accepting a suggestion (transition to approved)
             (resource.data.approvalStatus == 'suggested_change' &&
              request.resource.data.approvalStatus == 'approved' &&
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['empoweredBy'])) ||

             // Allow resubmitting (transition to pending)
             (resource.data.approvalStatus in ['rejected', 'suggested_change'] &&
              request.resource.data.approvalStatus == 'pending' &&
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['empoweredBy'])) ||

             // Otherwise, restrict critical fields
             !request.resource.data.diff(resource.data).affectedKeys().hasAny([
               'approvalStatus',      // Can't self-approve
               'targetCount',         // Can't change goal parameters
               'sessionsPerWeek',     // Can't change goal parameters
               'giverActionTaken',    // Can't reset giver action
               'empoweredBy',         // Can't change giver
               'approvalDeadline'     // Can't extend deadline
             ])
           ))
        )
        // SECURITY: Add value validation for numeric fields
        && (!('weeklyCount' in request.resource.data.diff(resource.data).affectedKeys()) ||
            (request.resource.data.weeklyCount >= 0 &&
             request.resource.data.weeklyCount <= request.resource.data.sessionsPerWeek &&
             // weeklyCount can only increment by 1 (session tick) or reset to 0 (week reset)
             (request.resource.data.weeklyCount == resource.data.weeklyCount + 1 ||
              request.resource.data.weeklyCount == 0)))
        && (!('targetCount' in request.resource.data.diff(resource.data).affectedKeys()) ||
            (request.resource.data.targetCount >= 1 &&
             request.resource.data.targetCount <= 5))
        && (!('sessionsPerWeek' in request.resource.data.diff(resource.data).affectedKeys()) ||
            (request.resource.data.sessionsPerWeek >= 1 &&
             request.resource.data.sessionsPerWeek <= 7))
        // Prevent direct goal completion manipulation
        && (!('isCompleted' in request.resource.data.diff(resource.data).affectedKeys())
            || (request.resource.data.isCompleted == true
                && resource.data.isCompleted == false
                && request.resource.data.currentCount >= request.resource.data.targetCount))
        // Prevent currentCount manipulation (can only increment by 1 or stay same)
        && (!('currentCount' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.currentCount == resource.data.currentCount
            || request.resource.data.currentCount == resource.data.currentCount + 1
            || request.resource.data.currentCount == resource.data.targetCount)
        )

        ||

        // (2) Valentine Partner Linking
        // Allow updating partner's goal ONLY to set partnerGoalId during atomic transaction
        // SECURITY: Verify both goals belong to same Valentine challenge
        (request.auth != null
        && resource.data.valentineChallengeId != null  // Must be a Valentine goal
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerGoalId', 'updatedAt'])  // Only partnerGoalId can be set
        && getAfter(/databases/$(database)/documents/goals/$(request.resource.data.partnerGoalId)).data.valentineChallengeId == resource.data.valentineChallengeId  // Same challenge
        && getAfter(/databases/$(database)/documents/goals/$(request.resource.data.partnerGoalId)).data.userId == request.auth.uid)  // User owns the partner goal

        ||

        // (3) Giver can ONLY update approval-related fields, personalized hints, and empower state
        (request.auth.uid == resource.data.empoweredBy
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'approvalStatus',
              'suggestedTargetCount',
              'suggestedSessionsPerWeek',
              'giverMessage',
              'giverActionTaken',
              'approvalRequestedAt',
              'approvalDeadline',
              'personalizedNextHint',
              'empowerPending',
              'updatedAt'
            ]))

        ||

        // (4) Valentine completion unlock
        // Allow either partner to unlock both goals once both are finished
        (request.auth != null
        && resource.data.valentineChallengeId != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUnlocked', 'unlockedAt'])
        && exists(/databases/$(database)/documents/valentineChallenges/$(resource.data.valentineChallengeId))
        && (
          get(/databases/$(database)/documents/valentineChallenges/$(resource.data.valentineChallengeId)).data.purchaserUserId == request.auth.uid ||
          get(/databases/$(database)/documents/valentineChallenges/$(resource.data.valentineChallengeId)).data.partnerUserId == request.auth.uid
        ))

        ||

        // (3) Giver can set personalized hint even without other approval fields
        ('empoweredBy' in resource.data &&
        request.auth.uid == resource.data.empoweredBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['personalizedNextHint', 'updatedAt']))

        ||

        // (5) Attaching a gift to a free goal (goal owner only)
        // SECURITY: Enforce 30-day gift attach deadline
        (request.auth.uid == resource.data.userId
         && 'isFreeGoal' in resource.data
         && resource.data.isFreeGoal == true
         && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['experienceGiftId', 'giftAttachedAt', 'empoweredBy', 'empowerPending', 'isMystery', 'updatedAt'])
         && request.resource.data.experienceGiftId is string
         && request.resource.data.experienceGiftId != ''
         && exists(/databases/$(database)/documents/experienceGifts/$(request.resource.data.experienceGiftId))
         && (!('giftAttachDeadline' in resource.data) || request.time < resource.data.giftAttachDeadline))

        ||

        // (6) Recipient links their goal to the giver's shared goal (Together challenge)
        // SECURITY: Only partnerGoalId + updatedAt may change; goal must be a shared challenge;
        // the authenticated user must own the partner goal being linked (proves they are the partner).
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerGoalId', 'updatedAt'])
         && resource.data.challengeType == 'shared'
         && request.resource.data.partnerGoalId is string
         && exists(/databases/$(database)/documents/goals/$(request.resource.data.partnerGoalId))
         && get(/databases/$(database)/documents/goals/$(request.resource.data.partnerGoalId)).data.userId == request.auth.uid)
      );

      /* ===============================
         BLOCK DELETES
         =============================== */
      allow delete: if false;

      /* ===============================
         NESTED SESSIONS
         =============================== */
      match /sessions/{sessionId} {
        // SECURITY FIX: Replaced broad `write` (which includes delete) with explicit create/update only.
        // Sessions are append-only audit logs — deletes are forbidden to preserve integrity.
        allow read, create, update: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/goals/$(goalId)).data.userId;
        allow delete: if false;
      }

      /* ===============================
         NESTED HINTS
         =============================== */
      // TODO: verify and remove if goalSessions/hints subcollections are no longer used
      match /hints/{hintId} {
        // SECURITY FIX: Replaced broad `write` (which includes delete) with explicit create/update only.
        // Hints are append-only audit logs — deletes are forbidden to preserve integrity.
        allow read, create, update: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/goals/$(goalId)).data.userId;
        allow delete: if false;
      }

      /* ===============================
         NESTED MOTIVATIONS (Free Goals)
         =============================== */
      match /motivations/{motivationId} {
        // Get by ID: any authenticated user (needed for transaction duplicate check on non-existent docs)
        allow get: if request.auth != null;
        // List: goal owner or motivation author only
        allow list: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/goals/$(goalId)).data.userId
          || request.auth.uid == resource.data.authorId
        );

        // Any authenticated user can leave a motivation (except the goal owner - you motivate others, not yourself)
        allow create: if request.auth != null
          && request.auth.uid != get(/databases/$(database)/documents/goals/$(goalId)).data.userId
          && request.auth.uid == request.resource.data.authorId
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 500;

        // Goal owner can mark motivations as seen
        allow update: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/goals/$(goalId)).data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seen']);
      }
    }

    /** =====================
     * 💝 VALENTINE CHALLENGES
     * ===================== **/
    match /valentineChallenges/{challengeId} {
      // Require authentication for all queries; limit result set size
      allow list: if request.auth != null && request.query.limit <= 100;

      // Allow reading individual challenge if user is a participant
      allow get: if request.auth != null &&
        (resource.data.purchaserUserId == request.auth.uid ||
         resource.data.partnerUserId == request.auth.uid ||
         // Allow get before user IDs are set (during redemption flow)
         !('purchaserUserId' in resource.data) ||
         resource.data.purchaserUserId == null);

      // Create: only via cloud functions (server-side after payment)
      allow create: if false;

      // Update: only if user owns the goal they're linking to this challenge
      // SECURITY: Prevents users from hijacking other people's challenges
      // NOTE: Uses getAfter() to support atomic transactions - it sees writes pending in the same transaction
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['purchaserCodeRedeemed', 'partnerCodeRedeemed',
                      'purchaserGoalId', 'partnerGoalId', 'purchaserUserId',
                      'partnerUserId', 'status', 'updatedAt',
                      'bothPartnersFinished', 'completionUnlockedAt', 'firstFinishedUserId', 'firstFinishedAt'])
        && (
          // If setting purchaserGoalId, verify user owns that goal
          !('purchaserGoalId' in request.resource.data.diff(resource.data).affectedKeys())
          || (getAfter(/databases/$(database)/documents/goals/$(request.resource.data.purchaserGoalId)).data.userId == request.auth.uid)
        )
        && (
          // If setting partnerGoalId, verify user owns that goal
          !('partnerGoalId' in request.resource.data.diff(resource.data).affectedKeys())
          || (getAfter(/databases/$(database)/documents/goals/$(request.resource.data.partnerGoalId)).data.userId == request.auth.uid)
        )
        && (
          // If marking completion unlock, ensure caller is a participant
          !('bothPartnersFinished' in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.auth.uid == resource.data.purchaserUserId ||
            request.auth.uid == resource.data.partnerUserId
          )
        );

      // Delete: never allowed from client
      allow delete: if false;
    }

    /** =====================
     * 🤝 SHARED CHALLENGES (Together mode — mirrors valentineChallenges rules)
     * ===================== **/
    match /sharedChallenges/{challengeId} {
      // Require authentication for all queries; limit result set size
      allow list: if request.auth != null && request.query.limit <= 100;

      // Allow reading individual challenge if user is a participant
      allow get: if request.auth != null &&
        (resource.data.purchaserUserId == request.auth.uid ||
         resource.data.partnerUserId == request.auth.uid ||
         // Allow get before user IDs are set (during redemption flow)
         !('purchaserUserId' in resource.data) ||
         resource.data.purchaserUserId == null);

      // Create: only via cloud functions (server-side after payment)
      allow create: if false;

      // Update: only if user owns the goal they're linking to this challenge
      // SECURITY: Prevents users from hijacking other people's challenges
      // NOTE: Uses getAfter() to support atomic transactions - it sees writes pending in the same transaction
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['purchaserCodeRedeemed', 'partnerCodeRedeemed',
                      'purchaserGoalId', 'partnerGoalId', 'purchaserUserId',
                      'partnerUserId', 'status', 'updatedAt',
                      'bothPartnersFinished', 'completionUnlockedAt', 'firstFinishedUserId', 'firstFinishedAt'])
        && (
          // If setting purchaserGoalId, verify user owns that goal
          !('purchaserGoalId' in request.resource.data.diff(resource.data).affectedKeys())
          || (getAfter(/databases/$(database)/documents/goals/$(request.resource.data.purchaserGoalId)).data.userId == request.auth.uid)
        )
        && (
          // If setting partnerGoalId, verify user owns that goal
          !('partnerGoalId' in request.resource.data.diff(resource.data).affectedKeys())
          || (getAfter(/databases/$(database)/documents/goals/$(request.resource.data.partnerGoalId)).data.userId == request.auth.uid)
        )
        && (
          // If marking completion unlock, ensure caller is a participant
          !('bothPartnersFinished' in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.auth.uid == resource.data.purchaserUserId ||
            request.auth.uid == resource.data.partnerUserId
          )
        );

      // Delete: never allowed from client
      allow delete: if false;
    }

    /** =====================
     * 🎁 EXPERIENCE GIFTS
     * ===================== **/
    match /experienceGifts/{giftId} {
      // List: allow authenticated users to query (for viewing own gifts and claiming)
      // Queries include: where('giverId', '==', userId) and where('claimCode', '==', code)
      // SECURITY NOTE: Firestore list rules cannot enforce query filters on resource.data,
      // so we cannot restrict by giverId/recipientId here. The limit is kept tight (10)
      // to reduce bulk scraping exposure. claimCode is only returned for docs the client
      // already knows to query for. Consider a Cloud Function proxy for stricter isolation.
      allow list: if request.auth != null && request.query.limit <= 10;

      // Get: allow giver or recipient only.
      // SECURITY FIX: Removed the "unclaimed gift readable by any authenticated user" branch —
      // it exposed claimCode, personalizedMessage, and paymentIntentId to arbitrary users.
      // Claiming is now handled server-side via Cloud Functions which bypass client rules.
      allow get: if request.auth != null &&
        (resource.data.giverId == request.auth.uid ||
         resource.data.recipientId == request.auth.uid);

      // Create: only via cloud functions (server-side)
      allow create: if false;

      // Update: allow giver to update personalizedMessage, recipient to update their gift, OR allow claiming pending gifts
      allow update: if request.auth != null && (
        // Giver updating personalized message
        (request.auth.uid == resource.data.giverId &&
         request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['personalizedMessage', 'updatedAt']))
        ||
        // Existing recipient updating their gift
        (request.auth.uid == resource.data.recipientId &&
         request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['status', 'claimedAt', 'claimedBy', 'updatedAt']))
        ||
        // Claiming a pending gift (setting recipientId for the first time)
        // SECURITY: Gift must not be expired at claim time
        (resource.data.status == 'pending' &&
         !('recipientId' in resource.data) &&
         request.resource.data.recipientId == request.auth.uid &&
         (!('expiresAt' in resource.data) || resource.data.expiresAt > request.time) &&
         request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['status', 'recipientId', 'claimedAt', 'claimedBy', 'updatedAt']))
        ||
        // Goal owner can claim an active gift when creating a goal
        // SECURITY: Must set recipientId to their own uid AND gift must not be expired
        (resource.data.status == 'active' &&
         request.resource.data.status == 'claimed' &&
         request.resource.data.recipientId == request.auth.uid &&
         (!('expiresAt' in resource.data) || resource.data.expiresAt > request.time) &&
         request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['status', 'recipientId', 'claimedAt', 'claimedBy', 'updatedAt']))
        ||
        // Allow recipient to revert their own claim (goal creation failed)
        (request.auth.uid == resource.data.recipientId
         && resource.data.status == 'claimed'
         && request.resource.data.status == 'pending'
         && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'recipientId', 'claimedBy', 'claimedAt', 'updatedAt']))
        ||
        // Allow giver to mark gift as redeemed (empower/attach flow)
        (request.auth.uid == resource.data.giverId
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['isRedeemed', 'redeemedAt', 'redeemedGoalId', 'status', 'claimedBy', 'updatedAt']))
        ||
        // Allow goal owner (recipient) to mark gift as redeemed when attaching to their goal
        // SECURITY: Verify caller owns the goal referenced in redeemedGoalId
        (request.resource.data.isRedeemed == true
            && request.resource.data.redeemedGoalId is string
            && exists(/databases/$(database)/documents/goals/$(request.resource.data.redeemedGoalId))
            && get(/databases/$(database)/documents/goals/$(request.resource.data.redeemedGoalId)).data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['isRedeemed', 'redeemedAt', 'redeemedGoalId', 'status', 'claimedBy', 'updatedAt']))
      );

      // Delete: never allowed from client
      allow delete: if false;
    }

    /** =====================
     * 💡 HINTS (flat collection)
     * ===================== **/
    match /hints/{hintId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      // Create: use request.resource.data (resource is null on create)
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      // Update/delete: use resource.data (document exists)
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    /** =====================
     * 👯 FRIEND REQUESTS
     * ===================== **/
    match /friendRequests/{requestId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.senderId ||
         request.auth.uid == resource.data.recipientId);

      // Admin read for admin dashboard (user detail page)
      // Uses inline get() — matches the pattern used by experiences/partnerInvites/etc.
      // The isAdmin() helper uses .exists() which has inconsistent behavior on list queries.
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true;

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.senderId
        // Must have required fields
        && request.resource.data.keys().hasAll(['senderId', 'recipientId', 'status', 'createdAt'])
        // Cannot send request to yourself
        && request.resource.data.senderId != request.resource.data.recipientId
        // Status must start as pending
        && request.resource.data.status == 'pending';

      // Allow update: restrict fields per role
      // Sender can only cancel; recipient can only accept/reject
      allow update: if request.auth != null &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['senderId', 'recipientId', 'createdAt']) &&
        (
          // Sender: can only cancel
          (request.auth.uid == resource.data.senderId &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
           request.resource.data.status in ['cancelled'])
          ||
          // Recipient: can accept or reject
          (request.auth.uid == resource.data.recipientId &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
           request.resource.data.status in ['accepted', 'rejected'])
        );

      // Allow delete: sender or recipient can delete the request
      // Note: for delete operations, request.resource doesn't exist, so only check resource.data
      allow delete: if request.auth != null &&
        (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.recipientId
        );
    }


    /** =====================
     * 👬 FRIENDS
     * ===================== **/
    match /friends/{friendDocId} {
      // Allow read and delete if user is part of the friendship
      allow read, delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.friendId);

      // Admin read for admin dashboard (user detail page)
      // Uses inline get() — matches the pattern used by experiences/partnerInvites/etc.
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true;

      // Creating friendship doc — creator must be one of the users AND a prior accepted
      // friendRequest must exist between these two users.
      // SECURITY FIX (HIGH-3): Added server timestamp enforcement (createdAt == request.time) and
      // addedAt field requirement to prevent replaying old friend creation writes.
      // SECURITY FIX (S2): Added friendRequest existence check to prevent fake friendship injection.
      // The requestId field must be present on the friends doc. We verify via get() on the pre-
      // transaction committed state (the transaction deletes the request, so get() still sees it
      // as existing at rule-evaluation time for the concurrent write).
      allow create: if request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.friendId is string
        && request.resource.data.userId != request.resource.data.friendId
        && request.resource.data.keys().hasAll(['userId', 'friendId', 'createdAt', 'addedAt'])
        && request.resource.data.keys().hasOnly(['userId', 'friendId', 'friendName', 'friendProfileImageUrl', 'createdAt', 'addedAt', 'requestId'])
        && (request.auth.uid == request.resource.data.userId || request.auth.uid == request.resource.data.friendId)
        && request.resource.data.createdAt == request.time;

      // Allow updates by either friend — restricted to safe fields only
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.uid == resource.data.friendId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['friendName', 'friendProfileImageUrl', 'updatedAt']);
    }



    /** =====================
     * 🔔 NOTIFICATIONS
     * ===================== **/
    match /notifications/{notificationId} {
      // Helper: check if two users are friends
      function areFriends(userId1, userId2) {
        return exists(/databases/$(database)/documents/friends/$(userId1 + '_' + userId2))
            || exists(/databases/$(database)/documents/friends/$(userId2 + '_' + userId1));
      }

      // Allow deletion by: target user, sender of friend request, recipient of goal change suggestion,
      // or goal owner for goal_progress notifications
      allow delete: if request.auth != null &&
        (
          request.auth.uid == resource.data.userId ||
          (
            resource.data.type == "friend_request" &&
            request.auth.uid == resource.data.data.senderId
          ) ||
          (
            resource.data.type == "goal_change_suggested" &&
            request.auth.uid == resource.data.userId
          ) ||
          (
            resource.data.type == 'goal_progress' &&
            'goalId' in resource.data.data &&
            exists(/databases/$(database)/documents/goals/$(resource.data.data.goalId)) &&
            get(/databases/$(database)/documents/goals/$(resource.data.data.goalId)).data.userId == request.auth.uid
          )
        );

      // Allow updates for notification owners (read/updatedAt/isStale only), friend request senders, and goal progress stale marking
      allow update: if request.auth != null &&
        (
          // Owner can only update read status, updatedAt, and isStale — not arbitrary fields
          (request.auth.uid == resource.data.userId &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt', 'isStale']))
          ||
          (
            resource.data.type == "friend_request" &&
            request.auth.uid == resource.data.data.senderId
          ) ||
          // Allow marking goal_progress notifications as stale
          // Only the giver (notification recipient) or goal owner (person completing sessions) can do this
          (
            resource.data.type == 'goal_progress' &&
            'goalId' in resource.data.data &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isStale']) &&
            request.resource.data.isStale == true &&
            // Allow if user is notification recipient (giver) OR the goal owner (recipient)
            (request.auth.uid == resource.data.userId ||
             (exists(/databases/$(database)/documents/goals/$(resource.data.data.goalId)) &&
              get(/databases/$(database)/documents/goals/$(resource.data.data.goalId)).data.userId == request.auth.uid))
          )
        );

      // Only notification owner can read their notifications
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;

      // SECURITY: Create rules with relationship validation
      allow create: if request.auth != null && (
        // Creating notification for yourself
        request.auth.uid == request.resource.data.userId
        ||
        // Friend requests: sender must be the authenticated user
        // SECURITY FIX (HIGH-4): Added exists() check on friendRequest doc to prevent notification spam
        // by users who have not actually sent a real friend request.
        (request.resource.data.type == 'friend_request' &&
         request.resource.data.senderId == request.auth.uid &&
         'requestId' in request.resource.data.data &&
         request.resource.data.data.requestId is string &&
         exists(/databases/$(database)/documents/friendRequests/$(request.resource.data.data.requestId)))
        ||
        // Valentine partner notifications: verify both users are in same challenge
        (request.resource.data.type == 'valentine_partner_progress' &&
         request.resource.data.keys().hasAll(['userId', 'type', 'data']) &&
         'goalId' in request.resource.data.data &&
         'challengeId' in request.resource.data.data &&
         exists(/databases/$(database)/documents/valentineChallenges/$(request.resource.data.data.challengeId)) &&
         (
           // Check if current user is the purchaser and notification is for partner
           (get(/databases/$(database)/documents/valentineChallenges/$(request.resource.data.data.challengeId)).data.purchaserUserId == request.auth.uid &&
            get(/databases/$(database)/documents/valentineChallenges/$(request.resource.data.data.challengeId)).data.partnerUserId == request.resource.data.userId)
           ||
           // Check if current user is the partner and notification is for purchaser
           (get(/databases/$(database)/documents/valentineChallenges/$(request.resource.data.data.challengeId)).data.partnerUserId == request.auth.uid &&
            get(/databases/$(database)/documents/valentineChallenges/$(request.resource.data.data.challengeId)).data.purchaserUserId == request.resource.data.userId)
         ))
        ||
        // Goal-related notifications: must have relationship to goal
        // SECURITY: Verify sender is either the goal owner or the goal's giver (empoweredBy)
        (request.resource.data.type in ['goal_completed', 'goal_progress', 'goal_approval_request',
                                         'goal_change_suggested', 'goal_approval_response',
                                         'personalized_hint_left', 'motivation_received',
                                         'free_goal_completed', 'free_goal_milestone',
                                         'shared_session', 'shared_start', 'shared_unlock',
                                         'shared_completion', 'payment_charged', 'payment_failed',
                                         'goal_edit_request', 'goal_edit_response'] &&
         request.resource.data.keys().hasAll(['userId', 'type', 'data']) &&
         'goalId' in request.resource.data.data &&
         exists(/databases/$(database)/documents/goals/$(request.resource.data.data.goalId)) &&
         (get(/databases/$(database)/documents/goals/$(request.resource.data.data.goalId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/goals/$(request.resource.data.data.goalId)).data.empoweredBy == request.auth.uid ||
          // Allow friends to send free goal notifications
          (request.resource.data.type in ['free_goal_completed', 'free_goal_milestone', 'motivation_received'] &&
           areFriends(request.auth.uid, request.resource.data.userId))))
        ||
        // Experience empower notifications: friend bought a gift for someone's goal
        // SECURITY: Verify sender is the gift giver
        (request.resource.data.type == 'experience_empowered' &&
         request.resource.data.keys().hasAll(['userId', 'type', 'data']) &&
         'goalId' in request.resource.data.data &&
         'giftId' in request.resource.data.data &&
         exists(/databases/$(database)/documents/goals/$(request.resource.data.data.goalId)) &&
         exists(/databases/$(database)/documents/experienceGifts/$(request.resource.data.data.giftId)) &&
         get(/databases/$(database)/documents/experienceGifts/$(request.resource.data.data.giftId)).data.giverId == request.auth.uid)
        ||
        // Post reactions: allow if post exists and the reactor is the authenticated user
        (request.resource.data.type == 'post_reaction' &&
         'postId' in request.resource.data.data &&
         exists(/databases/$(database)/documents/feedPosts/$(request.resource.data.data.postId)) &&
         request.resource.data.data.reactorId == request.auth.uid)
        ||
        // Post comments: allow if post exists and the commenter is the authenticated user
        (request.resource.data.type == 'post_comment' &&
         'postId' in request.resource.data.data &&
         exists(/databases/$(database)/documents/feedPosts/$(request.resource.data.data.postId)) &&
         request.resource.data.data.commenterId == request.auth.uid)
      );

    }


    /** =====================
     * 🌍 EXPERIENCES (public)
     * ===================== **/
    match /experiences/{experienceId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.userType == 'partner';
    }

    /** =====================
     * 📂 CATEGORIES (public read, admin write)
     * ===================== **/
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true
        && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.userType == 'partner';
    }

    /** =========================================================
     * 💌 PARTNER INVITES
     * ========================================================= **/
      match /partnerInvites/{inviteId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true ||
          resource.data.email == request.auth.token.email
        );

        allow create: if request.auth != null
          && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true
          && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.userType == 'partner'
          && request.resource.data.status == 'pending'
          && request.resource.data.createdBy == request.auth.uid
          && (
            !('createdByEmail' in request.resource.data)
            || request.resource.data.createdByEmail is string
            || request.resource.data.createdByEmail == null
          )
          && (!('email' in request.resource.data) || (request.resource.data.email is string && request.resource.data.email.size() <= 254))
          && (!('targetUid' in request.resource.data) || request.resource.data.targetUid is string)
          && request.resource.data.keys().hasOnly([
            'status', 'createdAt', 'createdBy', 'createdByEmail', 'email', 'targetUid'
          ]);

        allow update, delete: if request.auth != null
          && get(/databases/$(database)/documents/partnerUsers/$(request.auth.uid)).data.isAdmin == true;
      }


    /** =====================
     * 📰 FEED POSTS
     * ===================== **/
    match /feedPosts/{postId} {
      // Helper: check if two users are friends
      function areFriends(userId1, userId2) {
        return exists(/databases/$(database)/documents/friends/$(userId1 + '_' + userId2))
            || exists(/databases/$(database)/documents/friends/$(userId2 + '_' + userId1));
      }

      // SECURITY DECISION (2026-03-09): List queries are readable by any authenticated
      // user (Firestore rules evaluate per-document, so areFriends() checks on list
      // would cause N×2 exists() calls — prohibitively expensive). List-level privacy
      // is enforced client-side via `where('userId', 'in', [friendIds])` server-side
      // filter in FeedService.getFriendsFeed (capped at 100 docs per query).
      //
      // SECURITY HARDENING (2026-04-17): Direct `get()` of a single post NOW requires
      // ownership or friendship. This closes the attack where a user enumerates post
      // IDs and fetches arbitrary goal-progress data. Legitimate direct reads
      // (CommentService.getDoc on comment-target, post-owner viewing own post) both
      // satisfy the check. `getFeedPost` is unused client-side.
      allow get: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || areFriends(request.auth.uid, resource.data.userId)
      );
      allow list: if request.auth != null && request.query.limit <= 100;

      // Create: users can create their own posts OR givers can create goal_approved posts for recipients
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.userId
        ||
        // Allow givers to create goal_approved posts on behalf of recipients
        (request.resource.data.type == 'goal_approved' &&
         exists(/databases/$(database)/documents/goals/$(request.resource.data.goalId)) &&
         get(/databases/$(database)/documents/goals/$(request.resource.data.goalId)).data.empoweredBy == request.auth.uid)
      );

      // Update: owner can update anything; others can only update aggregated counts
      // with validation to prevent arbitrary count manipulation
      allow update: if request.auth != null && (
        // Owner can update anything
        request.auth.uid == resource.data.userId
        ||
        // Others can only update aggregated counts (for reactions/comments)
        // Counts can only change by small amounts (prevent setting to arbitrary values)
        // reactionCounts map: at most 1 key may change per write (prevents bulk manipulation)
        (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactionCounts', 'commentCount'])
         && (!('commentCount' in request.resource.data.diff(resource.data).affectedKeys()) ||
             (request.resource.data.commentCount >= resource.data.commentCount - 1 &&
              request.resource.data.commentCount >= 0 &&
              request.resource.data.commentCount <= resource.data.commentCount + 1))
         && (!('reactionCounts' in request.resource.data.diff(resource.data).affectedKeys()) ||
             request.resource.data.reactionCounts.diff(resource.data.reactionCounts).affectedKeys().size() <= 2))
      );

      // Delete: only owner
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;

      /** Reactions subcollection **/
      match /reactions/{reactionId} {
        // Read: authenticated user; list queries capped at 50 to prevent bulk scraping
        allow get: if request.auth != null;
        allow list: if request.auth != null && request.query.limit <= 50;

        // Create: users can create their own reactions
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;

        // Delete: users can delete their own reactions
        allow delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }

      /** Comments subcollection **/
      match /comments/{commentId} {
        // Read: authenticated user; list queries capped at 50 to prevent bulk scraping
        allow get: if request.auth != null;
        allow list: if request.auth != null && request.query.limit <= 50;

        // Create: authenticated users can comment
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;

        // Update: own comments OR liking (only likedBy/likeCount fields).
        // SECURITY FIX: likedBy updates now require the caller's UID to be present in the updated array,
        // preventing users from inserting or removing arbitrary UIDs in the likedBy list.
        allow update: if request.auth != null
          && (resource.data.userId == request.auth.uid
              || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likeCount'])
                  && request.auth.uid in resource.data.likedBy));

        // Delete: own comments only
        allow delete: if request.auth != null
          && resource.data.userId == request.auth.uid;
      }
    }


    /** =====================
     * 📋 GOAL SESSIONS
     * ===================== **/
    // TODO: verify and remove if goalSessions/hints subcollections are no longer used
    match /goalSessions/{goalId} {
      match /sessions/{sessionId} {
        // Read/write: only the goal owner
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/goals/$(goalId))
          && get(/databases/$(database)/documents/goals/$(goalId)).data.userId == request.auth.uid;
      }
    }

    /** =====================
     * 💳 PROCESSED PAYMENTS
     * ===================== **/
    match /processedPayments/{paymentId} {
      // Server-side only — no client access
      allow read, write: if false;
    }

    /** =====================
     * ⏱️ RATE LIMITS
     * ===================== **/
    match /rateLimits/{limitId} {
      // Server-side only — no client access
      allow read, write: if false;
    }

    /** =====================
     * 📊 ANALYTICS EVENTS
     * ===================== **/
    match /events/{eventId} {
      // Write-only: authenticated users AND anonymous (pre-auth) sessions can create events.
      // Anonymous events use userId == 'anonymous'; authenticated must match their uid.
      // This enables pre-signup funnel measurement (landing → signup conversion).
      // SECURITY: Field validation prevents arbitrary data injection; client-side rate limit
      // (60 events/min/session in AnalyticsService) limits anonymous spam.
      allow create: if
        (request.auth == null
          ? request.resource.data.userId == 'anonymous'
          : (request.resource.data.userId == request.auth.uid || request.resource.data.userId == 'anonymous'))
        && request.resource.data.keys().hasOnly(['eventName', 'category', 'userId', 'timestamp', 'properties', 'sessionId', 'screenName', 'userAgent', 'environment'])
        && request.resource.data.eventName is string
        && request.resource.data.eventName.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 50
        && request.resource.data.userId is string
        && request.resource.data.userId.size() <= 128
        && (!('screenName' in request.resource.data) || (
          request.resource.data.screenName is string &&
          request.resource.data.screenName.size() <= 100))
        && (!('userAgent' in request.resource.data) || (
          request.resource.data.userAgent is string &&
          request.resource.data.userAgent.size() <= 500))
        && (!('environment' in request.resource.data) || (
          request.resource.data.environment is string &&
          request.resource.data.environment.size() <= 20));
      allow read, update, delete: if false;
    }

    /** =====================
     * 🐛 ERROR LOGS
     * ===================== **/
    match /errors/{errorId} {
      // Anyone can create (ErrorBoundary and AuthScreen may fire before/during auth)
      // SECURITY: Validate structure and enforce size limits to prevent DoS
      allow create: if
        request.resource.data.keys().hasAll(['message', 'timestamp']) &&
        request.resource.data.keys().hasOnly([
          'message', 'stack', 'context', 'screenName',
          'userId', 'timestamp', 'userAgent', 'additionalData'
        ]) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 1000 &&
        (!('stack' in request.resource.data) || (
          request.resource.data.stack is string &&
          request.resource.data.stack.size() <= 2000)) &&
        (!('context' in request.resource.data) || (
          request.resource.data.context is string &&
          request.resource.data.context.size() <= 200)) &&
        (!('screenName' in request.resource.data) || (
          request.resource.data.screenName is string &&
          request.resource.data.screenName.size() <= 100)) &&
        (!('userId' in request.resource.data) || (
          request.resource.data.userId is string &&
          request.resource.data.userId.size() <= 128)) &&
        (!('userAgent' in request.resource.data) || (
          request.resource.data.userAgent is string &&
          request.resource.data.userAgent.size() <= 500));
      allow read, update, delete: if false;
    }

    /** =====================================================================
     * 🧾 LEGACY partnerCoupons/{partnerId}/coupons
     * ===================================================================== **/
    match /partnerCoupons/{partnerId} {
      match /coupons/{couponId} {
        // Partner can read their own (legacy)
        allow read: if request.auth != null &&
          request.auth.uid == partnerId &&
          isPartner(request.auth.uid);

        // Partner can update only specific fields
        allow update: if request.auth != null &&
          request.auth.uid == partnerId &&
          isPartner(request.auth.uid) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'redeemedAt']);

        // No client create/delete
        allow create, delete: if false;
      }
    }
  }
}
